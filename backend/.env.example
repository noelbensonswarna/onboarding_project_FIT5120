# Server Configuration
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=debug

# API Settings
API_TIMEOUT=5000

# Cache Settings
CACHE_TTL=3600

# Database Configuration (AWS RDS MySQL)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
